{
    "name": "fastor/fastor",
    "description": "High-performance, async-by-default PHP framework inspired by FastAPI.",
    "version": "0.1.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fastor Team",
            "email": "hello@fastor.io"
        }
    ],
    "keywords": [
        "fastapi",
        "php",
        "async",
        "swoole",
        "performance",
        "mlops",
        "microservices"
    ],
    "require": {
        "php": ">=8.2",
        "openswoole/core": "^22.0",
        "laminas/laminas-diactoros": "^3.0",
        "nikic/fast-route": "^1.3",
        "cuyz/valinor": "^1.0",
        "cycle/orm": "^2.0",
        "cycle/annotated": "^3.0",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Fastor\\": "Fastor/"
        },
        "files": [
            "Fastor/helpers.php"
        ]
    },
    "bin": [
        "Fastor/bin/fastor"
    ],
    "scripts": {
        "post-install-cmd": [
            "php Fastor/bin/fastor init"
        ],
        "post-update-cmd": [
            "php Fastor/bin/fastor init"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}